# ===== LLM Providers =====
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible local 
server (llama.cpp llama-server, LM Studio, vLLM).
# Must include /v1 (e.g. http://127.0.0.1:8080/v1 ). When set, PM_MODEL /
# DEV_MODEL etc. should use provider prefix openai/ with the model id your
# server expects (often anything works if only one GGUF is loaded).
# From Docker Compose: localhost is INSIDE the container — use the host machine:
#   OPENAI_BASE_URL=http://host.docker.internal:8080/v1
# docker-compose.yml adds extra_hosts (host-gateway) so host.docker.internal resolves.
#
# Critical: llama-server must LISTEN on all interfaces, not loopback-only, or the
# container cannot connect. Use --host 0.0.0.0 (NOT 127.0.0.1), e.g.:
#   llama-server.exe ... --host 0.0.0.0 --port 8080
#
# Quick test from inside the backend container after `docker compose up`:
#   docker exec -it tdd_backend python -c "import urllib.request; print(urllib.request.urlopen('http://host.docker.internal:8080/v1/models', timeout=5).read()[:200])"
# OPENAI_REQUEST_TIMEOUT=300   # seconds; local GGUF inference can be slow
# If OPENAI_BASE_URL is set and you omit OPENAI_API_KEY, the app injects "not-needed"
# for local servers. If you set a real OPENAI_API_KEY, that value is always used
# (including alongside OPENAI_BASE_URL for hybrid or proxy setups).

# ----- Researcher on cloud OpenAI while OPENAI_BASE_URL is local (hybrid) -----
# When most roles use a local OpenAI-compatible server but RESEARCHER_MODEL is
# openai/... and should call OpenAI's API, use one of:
#   RESEARCHER_USE_PLATFORM_OPENAI=true
#     → researcher ChatOpenAI has no base_url (SDK default → api.openai.com).
#     → set a real OPENAI_API_KEY (not "not-needed").
#   RESEARCHER_OPENAI_BASE_URL=https://api.openai.com/v1
#     → explicit researcher host; wins over RESEARCHER_USE_PLATFORM_OPENAI if both set.
# If neither is set, the researcher inherits OPENAI_BASE_URL like other openai/ roles.

# ----- Grader on cloud OpenAI while OPENAI_BASE_URL is local (hybrid) -----
# Same pattern as the researcher when GRADER_MODEL is openai/... (e.g. openai/gpt-4.1-mini):
#   GRADER_USE_PLATFORM_OPENAI=true
#   GRADER_OPENAI_BASE_URL=https://api.openai.com/v1
# If neither is set, the grader inherits OPENAI_BASE_URL.

# ----- Per-role: local / quirky OpenAI-compatible server (openai/... only) -----
# Set true only when that role's openai/... traffic hits llama.cpp, LM Studio, vLLM,
# etc. (tool_choice and schemas may differ from OpenAI's API). Leave false for
# the real OpenAI API or a fully compatible proxy — including when OPENAI_BASE_URL
# points at https://api.openai.com/v1.
# PM_IS_LOCAL=false
# RESEARCHER_IS_LOCAL=false
# LEAD_IS_LOCAL=false
# DEV_IS_LOCAL=false
# BACKEND_DEV_IS_LOCAL=false
# FRONTEND_DEV_IS_LOCAL=false
# GRADER_IS_LOCAL=false

# ----- Cloud example -----
# PM_MODEL=anthropic/claude-sonnet-4-6
# RESEARCHER_MODEL=openai/gpt-4o
# LEAD_MODEL=anthropic/claude-sonnet-4-6
# DEV_MODEL=anthropic/claude-sonnet-4-6
# GRADER_MODEL=openai/gpt-4.1-mini
#   + GRADER_USE_PLATFORM_OPENAI=true   # grader hits api.openai.com, not OPENAI_BASE_URL

# ----- Local llama.cpp (all roles via ChatOpenAI + your server) -----
# PM_MODEL=openai/meta-llama-Meta-Llama-3.1-8B-Instruct-Q4_K_M
# RESEARCHER_MODEL=openai/meta-llama-Meta-Llama-3.1-8B-Instruct-Q4_K_M
# LEAD_MODEL=openai/meta-llama-Meta-Llama-3.1-8B-Instruct-Q4_K_M
# DEV_MODEL=openai/meta-llama-Meta-Llama-3.1-8B-Instruct-Q4_K_M
# BACKEND_DEV_MODEL=openai/meta-llama-Meta-Llama-3.1-8B-Instruct-Q4_K_M
# FRONTEND_DEV_MODEL=openai/meta-llama-Meta-Llama-3.1-8B-Instruct-Q4_K_M
# GRADER_MODEL=openai/meta-llama-Meta-Llama-3.1-8B-Instruct-Q4_K_M
# EMBEDDING_PROVIDER=local
# MAX_OUTPUT_TOKENS=1024
# OPENAI_REQUEST_TIMEOUT=300
# Prefer a cloud PM when local llama.cpp struggles with tool-calling JSON:
# PM_MODEL=anthropic/claude-sonnet-4-6
# On llama-server: use --parallel 1 and consider --cache-ram 0 after stuck slots;
# restart the server if KV cache errors persist after cancelling backend runs.
# Researcher web_search: set TAVILY_API_KEY for local openai/ models, or use Anthropic
# keys when WEB_SEARCH_PROVIDER=auto and no Tavily key.

# ===== PostgreSQL (tickets + LangGraph checkpointer) =====
POSTGRES_USER=tdd
POSTGRES_PASSWORD=tdd_dev_password
POSTGRES_DB=tdd_agentic
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://tdd:tdd_dev_password@postgres:5432/tdd_agentic
CHECKPOINTER_URL=postgresql://tdd:tdd_dev_password@postgres:5432/tdd_agentic

# ===== Qdrant (RAG vector DB) =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# ===== Embeddings =====
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===== Web search (researcher tool ``web_search``) =====
# auto — use Tavily if TAVILY_API_KEY is set, otherwise Anthropic.
# anthropic — Claude-hosted search only (WEB_SEARCH_* below apply).
# tavily — API search only (works with local LLMs; ignores WEB_SEARCH_*).
WEB_SEARCH_PROVIDER=auto
TAVILY_API_KEY=
WEB_SEARCH_MODEL=claude-haiku-4-5
WEB_SEARCH_TOOL_VERSION=web_search_20260209

# ----- Agent harness (LangChain Deep Agents) -----
# Researcher uses the Deep Agents harness by default (virtual FS + context middleware).
# Set to false to restore the legacy in-process tool loop and fs_* tools.
# For openai/... researcher on the real OpenAI API, leave RESEARCHER_IS_LOCAL=false so
# the first model hop can require a tool call; set RESEARCHER_IS_LOCAL=true for local
# servers that reject tool_choice=required.
USE_DEEP_AGENT_RESEARCHER=true
# Max LangGraph steps for one inner deep-agent turn (raises recursion limit if too low).
DEEP_AGENT_RECURSION_LIMIT=80
ANTHROPIC_REQUESTS_PER_SECOND=0.4
ANTHROPIC_BURST=1
OPENAI_REQUESTS_PER_SECOND=1.0
OPENAI_BURST=2

# Inline retry-with-backoff for transient errors (429, 5xx).
LLM_MAX_RETRIES=4
LLM_RETRY_INITIAL_DELAY=2.0
LLM_RETRY_MAX_DELAY=60.0

# Max output tokens per LLM call.
MAX_OUTPUT_TOKENS=2048

# Checkpoint GET cache (seconds). Cheap default keeps UI polling from piling
# expensive LangGraph compilations on the API process.
CHECKPOINTS_CACHE_TTL_SECONDS=15

# LLM tracing: INFO line per LangGraph LLM forward with slug + URL hint for chat completions.
LLM_INVOKE_LOG_EACH_CALL=true
# Extremely noisy — OpenAI-compatible client HTTP DEBUG (openai/httpcore).
LLM_OPENAI_HTTP_DEBUG=false

# ===== Langfuse observability =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# ===== Backend API =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ===== Workspace for generated projects =====
WORKSPACE_ROOT=/app/workspace
